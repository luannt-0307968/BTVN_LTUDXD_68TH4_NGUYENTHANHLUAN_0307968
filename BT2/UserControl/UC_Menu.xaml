<UserControl x:Class="BT2.UserControl.UC_Menu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BT2.UserControl"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Ribbon>
            <RibbonTab Header="Home">
                <RibbonGroup Header="Clipboard">
                    <RibbonButton Label="Paste" KeyTip="V"
            ToolTip="Paste (Ctrl+V)" LargeImageSource="/Icons/Paste.png"/>
                    <RibbonButton x:Name="btn_Cut" Label="Cut" SmallImageSource="/Icons/Cut_32px.png"/>
                    <RibbonButton Label="Copy" SmallImageSource="/Icons/Bookmark.png"/>
                    <RibbonButton Label="Delete" SmallImageSource="/Icons/Delete.png"/>
                </RibbonGroup>

                <RibbonGroup Header="Link">
                    <RibbonButton Label="Add Link" SmallImageSource="/Icons/Add Link.png"/>
                    <RibbonCheckBox Label="Left"                                    
                   SmallImageSource="/Icons/Left Arrow.png"/>
                    <RibbonCheckBox Label="Right"                                    
                   SmallImageSource="/Icons/Right Arrow.png"/>
                </RibbonGroup>
            </RibbonTab>

        </Ribbon>
    </Grid>
</UserControl>
