<Window x:Class="BT4.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BT4"
        xmlns:UserControl="clr-namespace:BT4.Views.UserControls"
        mc:Ignorable="d"
        WindowState="Maximized"
        Title="MainWindow" Height="800" Width="800">
    <Grid>
        <!--Định nghĩa bố cục-->
        <Grid.RowDefinitions>
            <RowDefinition Height="150"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!--Định nghĩa các control trong window-->
        <StackPanel x:Name="Panel0" Grid.Row="0"/>
        <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Visible" >

        </Frame>
        <UserControl:UC_Status Grid.Row="2"/>
    </Grid>
</Window>
