<Window x:Class="BT3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BT3"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid ShowGridLines="True">


        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" ShowGridLines="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>

            <GroupBox Header="Thông tin" Grid.Row="0" Margin="5">

                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Mã hiệu:"/>
                        <TextBox x:Name="txtMark" Width="100" Margin="5" Text="{Binding Mark}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <Label Content="b:"/>
                        <TextBox x:Name="txtb" Width="100" Margin="40 5 5 5" Text="{Binding b}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <Label Content="a:"/>
                        <TextBox x:Name="txta" Text="{Binding a}" Width="100" Margin="40 5 5 5"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <Label Content="M:" ToolTip="Nhập Mômen" />
                        <TextBox x:Name="txtM" HorizontalAlignment="Center" Text="{Binding M}" Width="100" Margin="35 5 5 5"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Vật Liệu" Grid.Row="1" Margin="5">
                <StackPanel Orientation="Vertical">

                    <StackPanel Orientation="Horizontal" Margin="5"  >
                        <Label Content="Bê tông:"/>
                        <ComboBox x:Name="cmb_BeTong" 
                           ItemsSource="{Binding Path=ConcreteMaterialList}"
                           DisplayMemberPath="Name"
                           SelectedItem="{Binding ConcreteMaterial}"
                           Width="80" 
                           Margin="5 0 0 0" SelectedIndex="1" >
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="5"  >
                        <Label Content="Cốt thép:"/>
                        <ComboBox x:Name="cmb_CotThep" Width="80" 
                           ItemsSource="{Binding Path=RebarMaterialList}"
                           DisplayMemberPath="Name"
                           SelectedItem="{Binding RebarMaterial}"
                           SelectedIndex="1" >
                        </ComboBox>
                    </StackPanel>
                </StackPanel>

            </GroupBox>

            <GroupBox Header="Hệ số àm việc" Grid.Row="2" Margin="5">
                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal" Margin="5"  >
                        <Label Content="HS điều kiện làm việc:"/>
                        <TextBox x:Name="txt_HSDKLV" Width="50" Margin="40 0 0 0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="5"  >
                        <Label Content="Hàm lượng cốt thép tối thiểu:"/>
                        <TextBox x:Name="txt_MuMin" Width="50" />
                    </StackPanel>

                </StackPanel>
            </GroupBox>


        </Grid>

        <Grid Grid.Column="1" ShowGridLines="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="5*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>

            <DataGrid x:Name="dtg_BeamList" Grid.Row="0" ItemsSource="{Binding BeamList, IsAsync=True}" 
     SelectedItem="{Binding CurrentBeam, Mode=TwoWay}"
     AutoGenerateColumns="False" 
     CanUserAddRows="False" Margin="10">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" />
                    <DataGridTextColumn Header="Mã hiệu" Binding="{Binding Mark}" />
                    <DataGridTextColumn Header="b" Binding="{Binding b}" />
                    <DataGridTextColumn Header="h" Binding="{Binding h }" />
                    <DataGridTextColumn Header="a" Binding="{Binding a}" />
                    <DataGridTextColumn Header="h0" Binding="{Binding h0}" />
                    <DataGridTextColumn Header="M (m)" Binding="{Binding M}" />
                    <DataGridTextColumn Header="Aₛ (cm²)" Binding="{Binding As, StringFormat=N2}" />
                    <DataGridTextColumn Header="Alpha_m (m)" Binding="{Binding AlphaM}" />
                    <DataGridTextColumn Header="Alpha_r (m)" Binding="{Binding AlphaR}" />
                    <DataGridTextColumn Header="Bài toán (m)" Binding="{Binding BaiToan}" />
                </DataGrid.Columns>
                <!--Dùng DataTrigger-->
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding BaiToan}" Value="Không thỏa mãn" >
                                <Setter Property="Background" Value="Red"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding BaiToan}" Value="Cốt kép" >
                                <Setter Property="Background" Value="Yellow"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding BaiToan}" Value="Cốt đơn" >
                                <Setter Property="Background" Value="LightBlue"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" >
                <Button x:Name="btnThemDam" Command="{Binding AddBeamCommand}" Content="Thêm dầm" Width="100"  Height="30"  />
                <Button x:Name="btnXoaDam" Command="{Binding RemoveBeamCommand}" Content="Xóa dầm" Width="100"  Height="30"  Margin="50 0 0 0" />
                <Button x:Name="btnTinhToanDam" Content="Tính toán"  Command="{Binding CalBeamCommand}" Width="100" Margin="50 0 0 0" Height="30"  />
            </StackPanel>


        </Grid>
    </Grid>
</Window>
